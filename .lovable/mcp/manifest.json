{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ojyzegzdlpjlbdhvqhav.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "clickonepro-mcp",
      "version": "0.6.0",
      "title": "ClickOne Pro MCP"
    },
    "tools": [
      {
        "name": "list_blog_posts",
        "title": "List blog posts",
        "description": "List blog posts from the ClickOne blog. Returns id, title, slug, status, published_at and views.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published",
                "archived",
                "all"
              ],
              "description": "Filter by post status. Defaults to published."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows to return (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_blog_post",
        "title": "Get blog post",
        "description": "Fetch a single blog post by slug, including its full content.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "The blog post slug, e.g. 'meu-post'."
            }
          },
          "required": [
            "slug"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_blog_post",
        "title": "Create blog post",
        "description": "Create a new blog post. Provide title and content (Markdown or HTML). Slug is auto-generated from the title if omitted. Set status='published' to publish immediately (published_at is set to now); otherwise it stays as draft. Requires admin (RLS).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 3,
              "description": "Post title."
            },
            "content": {
              "type": "string",
              "minLength": 10,
              "description": "Full post body (Markdown or HTML)."
            },
            "slug": {
              "type": "string",
              "description": "URL slug. Auto-generated from title if omitted."
            },
            "excerpt": {
              "type": "string",
              "description": "Short summary shown in listings."
            },
            "cover_image": {
              "type": "string",
              "format": "uri",
              "description": "Cover image URL."
            },
            "category_id": {
              "type": "string",
              "format": "uuid"
            },
            "author": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published"
              ],
              "description": "Default 'draft'."
            },
            "meta_title": {
              "type": "string"
            },
            "meta_description": {
              "type": "string"
            },
            "read_time": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120
            }
          },
          "required": [
            "title",
            "content"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "update_blog_post",
        "title": "Update blog post",
        "description": "Update an existing blog post by id or current slug. Any field (title, slug, content, excerpt, cover_image, meta_*, read_time) may be omitted to keep the current value. Toggle publish state with status='draft'|'published' — switching to 'published' sets published_at=now if it was empty; switching to 'draft' clears published_at. Requires admin (RLS).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Post id. Provide id OR slug."
            },
            "slug": {
              "type": "string",
              "description": "Current slug. Provide id OR slug."
            },
            "title": {
              "type": "string",
              "minLength": 3
            },
            "new_slug": {
              "type": "string",
              "description": "New URL slug. If omitted, slug is unchanged."
            },
            "content": {
              "type": "string",
              "minLength": 10
            },
            "excerpt": {
              "type": "string"
            },
            "cover_image": {
              "type": "string",
              "format": "uri"
            },
            "category_id": {
              "type": "string",
              "format": "uuid"
            },
            "author": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published"
              ]
            },
            "meta_title": {
              "type": "string"
            },
            "meta_description": {
              "type": "string"
            },
            "read_time": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120
            },
            "regenerate_slug_from_title": {
              "type": "boolean",
              "description": "If true and new_slug omitted, regenerate slug from the (new or existing) title."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "preview_blog_post",
        "title": "Preview blog post",
        "description": "Render a blog post preview WITHOUT saving. Converts Markdown to HTML (or passes HTML through), returns a plain-text excerpt, word count, and estimated read time (minutes). Use before `create_blog_post` or `update_blog_post` to review output. `intended_status` and `intended_slug` are echoed back so agents can chain into a save call.",
        "annotations": {
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "content": {
              "type": "string",
              "minLength": 1,
              "description": "Markdown or HTML."
            },
            "excerpt": {
              "type": "string"
            },
            "intended_status": {
              "type": "string",
              "enum": [
                "draft",
                "published"
              ]
            },
            "intended_slug": {
              "type": "string"
            },
            "words_per_minute": {
              "type": "integer",
              "minimum": 80,
              "maximum": 400,
              "description": "Reading speed (default 220 wpm)."
            }
          },
          "required": [
            "title",
            "content"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "seo_checklist_blog_post",
        "title": "SEO checklist for a blog post",
        "description": "Analyze a draft post BEFORE saving and return an SEO checklist: suggested meta_title (≤60), meta_description (≤160), heading structure audit (single H1, hierarchy), top keywords with density, and pass/fail checks. Purely computational — does not touch the database.",
        "annotations": {
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "content": {
              "type": "string",
              "minLength": 10,
              "description": "Markdown or HTML."
            },
            "excerpt": {
              "type": "string"
            },
            "focus_keyword": {
              "type": "string",
              "description": "Primary keyword to target. If omitted, the tool infers one from the title/content."
            },
            "top_n_keywords": {
              "type": "integer",
              "minimum": 3,
              "maximum": 25
            }
          },
          "required": [
            "title",
            "content"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "schedule_blog_post_publish",
        "title": "Schedule blog post publication",
        "description": "Schedule a blog post to auto-publish at a future date. Sets status='draft' and published_at=<publish_at>. A backend cron job (every 5 minutes) flips status to 'published' once the scheduled time is reached. Pass `cancel: true` to cancel a schedule (clears published_at and keeps draft). Pass a past date to publish immediately. Requires admin (RLS).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Post id. Provide id OR slug."
            },
            "slug": {
              "type": "string",
              "description": "Current slug. Provide id OR slug."
            },
            "publish_at": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp for auto-publish. Required unless cancel=true."
            },
            "cancel": {
              "type": "boolean",
              "description": "If true, clears the schedule and keeps the post as draft."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_leads",
