{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ojyzegzdlpjlbdhvqhav.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "clickonepro-mcp",
      "version": "0.4.0",
      "title": "ClickOne Pro MCP"
    },
    "tools": [
      {
        "name": "list_blog_posts",
        "title": "List blog posts",
        "description": "List blog posts from the ClickOne blog. Returns id, title, slug, status, published_at and views.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published",
                "archived",
                "all"
              ],
              "description": "Filter by post status. Defaults to published."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max rows to return (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_blog_post",
        "title": "Get blog post",
        "description": "Fetch a single blog post by slug, including its full content.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "The blog post slug, e.g. 'meu-post'."
            }
          },
          "required": [
            "slug"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_blog_post",
        "title": "Create blog post",
        "description": "Create a new blog post. Provide title and content (Markdown or HTML). Slug is auto-generated from the title if omitted. Set status='published' to publish immediately (published_at is set to now); otherwise it stays as draft. Requires admin (RLS).",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 3,
              "description": "Post title."
            },
            "content": {
              "type": "string",
              "minLength": 10,
              "description": "Full post body (Markdown or HTML)."
            },
            "slug": {
              "type": "string",
              "description": "URL slug. Auto-generated from title if omitted."
            },
            "excerpt": {
              "type": "string",
              "description": "Short summary shown in listings."
            },
            "cover_image": {
              "type": "string",
              "format": "uri",
              "description": "Cover image URL."
            },
            "category_id": {
              "type": "string",
              "format": "uuid"
            },
            "author": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "published"
              ],
              "description": "Default 'draft'."
            },
            "meta_title": {
              "type": "string"
            },
            "meta_description": {
              "type": "string"
            },
            "read_time": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120
            }
          },
          "required": [
            "title",
            "content"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_leads",
        "title": "List leads",
        "description": "List recent leads captured by the ClickOne site. Requires admin access; RLS enforces this on the database side.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Max rows to return (default 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_lead",
        "title": "Get lead",
        "description": "Fetch a single lead by id or email. Requires admin access via RLS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Lead UUID."
            },
            "email": {
              "type": "string",
              "format": "email",
              "description": "Lead email."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_lead",
        "title": "Create lead",
        "description": "Create a new lead in the ClickOne CRM. Requires at least an email. Optional fields: name, phone, company, source, utm_source, utm_medium, utm_campaign, status.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "description": "Lead email (required)."
            },
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "company": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "description": "Where the lead came from (e.g. 'mcp', 'landing-page')."
            },
            "utm_source": {
              "type": "string"
            },
            "utm_medium": {
              "type": "string"
            },
            "utm_campaign": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "description": "Lead status (default 'new')."
            }
          },
          "required": [
            "email"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "update_lead_status",
        "title": "Update lead status",
        "description": "Update the status of an existing lead by id. Common values: 'new', 'contacted', 'qualified', 'converted', 'lost'. Requires admin access via RLS.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Lead UUID."
            },
            "status": {
              "type": "string",
              "minLength": 1,
              "description": "New status value."
            }
          },
          "required": [
            "id",
            "status"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "schedule_demo",
        "title": "Schedule demo",
        "description": "Register a demo booking for a lead and send a confirmation email. Auto-creates or updates the linked lead (status → 'demo_scheduled'). Public tool: no login required.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "description": "Lead email (required)."
            },
            "scheduled_at": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 date-time of the demo (e.g. 2026-07-25T14:00:00Z)."
            },
            "name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "company": {
              "type": "string"
            },
            "timezone": {
              "type": "string",
              "description": "IANA timezone. Default 'America/Sao_Paulo'."
            },
            "notes": {
              "type": "string"
            },
            "send_confirmation": {
              "type": "boolean",
              "description": "Send confirmation email (default true)."
            }
          },
          "required": [
            "email",
            "scheduled_at"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
